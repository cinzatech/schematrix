{
  "$id": "https://example.com/person.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Different options",
  "description": "An object with a key that might hold different types",
  "type": "object",
  "properties": {
    "option": {
      "type": [
        "string",
        "object"
      ],
      "properties": {
        "foo": {
          "type": "integer"
        }
      },
      "required": [
        "option"
      ],
      "description": "Maybe of different types"
    }
  }
}