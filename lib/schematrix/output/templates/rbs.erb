    <%= rbs_attr_accessors %>

    def initialize: (<%= rbs_initialize_params %>) -> void
    <% unless @additional_properties.nil? %>

    def []: (Symbol) -> <%= additional_properties_type %>

    def []=: (Symbol, <%= additional_properties_type %>) -> <%= additional_properties_type %>
    <% end %>
  end
end
