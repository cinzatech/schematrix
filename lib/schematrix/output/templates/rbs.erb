module <%= @module_name %>
  <%= documentation_comment(@object) %>
  class <%= @class_name %>
    <%= rbs_attr_accessors(@path, @object) %>

    def initialize: (<%= rbs_initialize_params(@path, @object.properties) %>) -> void
    <% unless @additional_properties.nil? %>

    def []: (Symbol) -> <%= additional_properties_type(@path, @additional_properties) %>

    def []=: (Symbol, <%= additional_properties_type(@path, @additional_properties) %>) -> <%= additional_properties_type(@path, @additional_properties) %>
    <% end %>
  end
end
