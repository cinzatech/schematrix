# typed: strict

module <%= @module_name %>
  <%= @documentation_comment %>
  class <%= @class_name %>
    sig { params(
      <%= constructor_signature_params %>
    ).void }
    def initialize(
      <%= constructor_arguments %>
    )
      <%= constructor_assignments %>
      <% unless @additional_properties.nil? %>
      @_extra = T.let({}, T::Hash[Symbol, <%= additional_properties_type %>])
      <% end %>
    end

    <%= sorbet_attr_accessors %>
    <% unless @additional_properties.nil? %>

    sig { params(key: Symbol).returns(<%= additional_properties_type %>) }
    def [](key)
      @_extra[key]
    end

    sig { params(key: Symbol, value: <%= %>).returns(<%= additional_properties_type %>) }
    def []=(key, value)
      @_extra[key] = value
    end
    <% end %>
  end
end
