# typed: strict

module <%= @module_name %>
  <%= documentation_comment(@object) %>
  class <%= @class_name %>
    sig { params(
      <%= constructor_signature_params(@properties) %>
    ).void }
    def initialize(
      <%= constructor_arguments(@properties) %>
    ); end

    <%= sorbet_attr_accessors(@properties) %>
    <% unless @additional_properties.nil? %>

    sig { params(key: Symbol).returns(<%= sorbet_type(@additional_properties) %>) }
    def [](key); end

    sig { params(key: Symbol, value: <%= %>).returns(<%= sorbet_type(@additional_properties) %>) }
    def []=(key, value); end
    <% end %>
  end
end
