# typed: strict

module <%= @module_name %>
  <%= @documentation_comment %>
  class <%= @class_name %>
    sig { params(
      <%= constructor_signature_params(@path, @properties) %>
    ).void }
    def initialize(
      <%= constructor_arguments(@properties) %>
    ); end

    <%= sorbet_attr_accessors(@path, @properties) %>
    <% unless @additional_properties.nil? %>

    sig { params(key: Symbol).returns(<%= additional_properties_type(@path, @additional_properties) %>) }
    def [](key); end

    sig { params(key: Symbol, value: <%= %>).returns(<%= additional_properties_type(@path, @additional_properties) %>) }
    def []=(key, value); end
    <% end %>
  end
end
