module <%= @module_name %>
  <%= @documentation_comment %>
  class <%= @class_name %>
    def initialize(
      <% unless @properties.nil? %>
      <%= constructor_arguments %>
      <% end %>
    )
      <%= constructor_assignments %>
      <% unless @additional_properties.nil? %>
      @_extra = {}
      <% end %>
    end

    <% unless @properties.nil? %>
    attr_accessor <%= plain_attr_accessor_list %>
    <% end %>
    <% unless @additional_properties.nil? %>

    def [](key)
      @_extra[key]
    end

    def []=(key, value)
      @_extra[key] = value
    end
    <% end %>
  end
end
