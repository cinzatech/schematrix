module <%= @module_name %>
  <%= @documentation_comment %>
  class <%= @class_name %>
    <%= rbs_attr_accessors %>

    def initialize: (
      <% unless @properties.nil? %>
      <%= rbs_initialize_params %>
      <% end %>
    ) -> void
    <% unless @additional_properties.nil? %>

    def []: (Symbol) -> <%= rbs_additional_properties_type %>

    def []=: (Symbol, <%= rbs_additional_properties_type %>) -> <%= rbs_additional_properties_type %>
    <% end %>
  end
end
